# Application
AQR_ENVIRONMENT=development
AQR_BACKEND_HOST=0.0.0.0
AQR_BACKEND_PORT=8000
AQR_DATABASE_URL=postgresql+psycopg://ai_quant:local_development_only@localhost:5432/ai_quant
AQR_DATABASE_ECHO=false
AQR_CORS_ORIGINS=["http://localhost:5173"]
AQR_ASHAREHUB_API_KEY=
AQR_ASHAREHUB_TIMEOUT_SECONDS=20
AQR_ASHAREHUB_SYNC_MAX_REQUESTS=20
AQR_AI_PROVIDER=disabled
AQR_AI_BASE_URL=https://api.openai.com/v1
AQR_AI_API_KEY=
AQR_AI_MODEL=
AQR_AI_TIMEOUT_SECONDS=30
AQR_AI_MAX_ATTEMPTS=2
AQR_AI_MAX_OUTPUT_CHARACTERS=6000
AQR_AI_MAX_OUTPUT_TOKENS=1200
AQR_RAG_EMBEDDING_PROVIDER=local_hash
AQR_RAG_EMBEDDING_BASE_URL=https://api.openai.com/v1
AQR_RAG_EMBEDDING_API_KEY=
AQR_RAG_EMBEDDING_MODEL=local-hash-v1
AQR_RAG_EMBEDDING_DIMENSIONS=256
AQR_RAG_EMBEDDING_TIMEOUT_SECONDS=30
AQR_RAG_EMBEDDING_MAX_ATTEMPTS=2
AQR_RAG_CHUNK_SIZE=1200
AQR_RAG_CHUNK_OVERLAP=200
AQR_RAG_MAX_DOCUMENT_BYTES=10485760

# Frontend
VITE_API_BASE_URL=http://localhost:8000
FRONTEND_PORT=5173

# PostgreSQL
POSTGRES_DB=ai_quant
POSTGRES_USER=ai_quant
POSTGRES_PASSWORD=local_development_only
POSTGRES_PORT=5432
